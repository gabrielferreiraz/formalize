# ============================================================
# Formalize — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA faça commit do arquivo .env.
# ============================================================

# ----------------------------------------------------------
# Banco de Dados (PostgreSQL)
# ----------------------------------------------------------
DATABASE_URL="postgresql://formalize:formalize@localhost:5432/formalize_dev?schema=public"

# ----------------------------------------------------------
# NextAuth.js
# ----------------------------------------------------------
# Gere com: openssl rand -base64 32
NEXTAUTH_SECRET="TROQUE_POR_UM_SEGREDO_FORTE"
NEXTAUTH_URL="http://localhost:3000"

# ----------------------------------------------------------
# Domínio raiz (multi-tenant)
# Usado pelo middleware para resolver subdomínios
# ----------------------------------------------------------
NEXT_PUBLIC_ROOT_DOMAIN="formalize.com.br"

# ----------------------------------------------------------
# Cloudflare R2 (Storage) — obrigatórios em lib/r2.ts
# ----------------------------------------------------------
# Endpoint S3 API (substitua ACCOUNT_ID pelo ID da conta Cloudflare)
R2_ENDPOINT="https://ACCOUNT_ID.r2.cloudflarestorage.com"

R2_ACCESS_KEY_ID="sua_r2_access_key_id"
R2_SECRET_ACCESS_KEY="sua_r2_secret_access_key"
R2_BUCKET_NAME="formalize"

# URL pública base para montar links aos objetos (domínio R2 público ou custom domain, sem barra final)
# Ex.: https://pub-xxxxx.r2.dev  ou  https://cdn.seudominio.com.br
R2_PUBLIC_URL="https://pub-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.r2.dev"

# ----------------------------------------------------------
# Gotenberg (HTML → PDF)
# ----------------------------------------------------------
# GOTENBERG_URL="https://seu-gotenberg.exemplo.com"

# ----------------------------------------------------------
# Desenvolvimento local
# ----------------------------------------------------------
# PORT=3000
